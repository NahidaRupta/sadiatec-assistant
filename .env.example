# ─────────────────────────────────────────────────────────────────────────────
# Payload CMS + Database
# ─────────────────────────────────────────────────────────────────────────────

# Neon PostgreSQL — use the POOLED connection string, not the direct one
# Format: postgresql://user:password@region.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@region.neon.tech/sadiatec?sslmode=require

# Secret for Payload CMS (JWT signing). Generate with: openssl rand -hex 32
PAYLOAD_SECRET=your_secret_key_here_at_least_32_chars

# ─────────────────────────────────────────────────────────────────────────────
# Next.js + Deployment
# ─────────────────────────────────────────────────────────────────────────────

# Public-facing server URL (for CMS embeds, API calls from the client)
# On Vercel: https://your-project.vercel.app
# On localhost: http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional: your node environment
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Sadiatec Assistant Widget
# ─────────────────────────────────────────────────────────────────────────────

# Staff notification webhook (optional but recommended)
# Slack incoming webhook: https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# LINE Notify: https://notify-api.line.me/api/notify (needs Authorization header)
# Discord (with shim): https://discordapp.com/api/webhooks/...
STAFF_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ─────────────────────────────────────────────────────────────────────────────
# Seed Data (Optional — for initial admin user creation)
# ─────────────────────────────────────────────────────────────────────────────

# Email and password for the initial admin user (created on first payload init)
PAYLOAD_SEED_EMAIL=admin@sadiatec.dev
PAYLOAD_SEED_PASSWORD=changeme

# ─────────────────────────────────────────────────────────────────────────────
# Analytics (Optional — if using PostHog or Google Analytics)
# ─────────────────────────────────────────────────────────────────────────────

# PostHog API key (for event tracking in the widget)
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx

# Google Analytics tracking ID
# NEXT_PUBLIC_GA_ID=G-xxx

# ─────────────────────────────────────────────────────────────────────────────
# Storage / Media (Optional — if using Cloudflare R2 or similar)
# ─────────────────────────────────────────────────────────────────────────────

# R2 credentials (if using Cloudflare R2 for media storage)
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET_NAME=sadiatec-media
